# Klasio production environment template.
# Copy to /opt/klasio/.env on the VM and fill in real values. NEVER commit the real .env.
#
#   cp docker/.env.example /opt/klasio/.env
#   chmod 600 /opt/klasio/.env
#
# Generate strong secrets with:
#   openssl rand -base64 32     # for passwords
#   openssl rand -base64 64     # for JWT_SECRET (must be >= 256 bits)

# ---- Postgres ----
POSTGRES_DB=klasio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_postgres_superuser_pw
KLASIO_APP_PASSWORD=CHANGE_ME_app_role_pw

# ---- JWT ----
JWT_SECRET=CHANGE_ME_min_64_bytes_base64
JWT_ACCESS_EXPIRATION=28800000
JWT_REFRESH_EXPIRATION=604800000

# ---- Frontend (self-hosted, wildcard subdomain per tenant) ----
# Used by the backend to build links in transactional emails.
# {tenantSlug} is replaced at send time with the tenant slug.
KLASIO_FRONTEND_URL_TEMPLATE=https://{tenantSlug}.klasio.club

# Browser-facing API URL (baked into the JS bundle at build time).
# Must include the /api/v1 path prefix because client code appends endpoint
# paths like /auth/login directly to this base.
NEXT_PUBLIC_API_URL=https://api.klasio.club/api/v1

# Server-side API URL used by Next.js API proxy routes (src/app/api/**).
# Must include /api/v1 -- proxy routes append /auth/login etc directly.
# Stays inside docker network, bypassing Caddy/TLS.
BACKEND_URL=http://api:8080/api/v1

# ---- CORS / cookies (backend) ----
# Comma-separated list of allowed origin patterns (Spring AllowedOriginPatterns
# format). Wildcards in the host part are supported.
CORS_ALLOWED_ORIGINS=https://klasio.club,https://*.klasio.club
# Cookie flags. In prod cookies must be Secure and shared across subdomains.
COOKIE_SECURE=true
COOKIE_DOMAIN=.klasio.club
COOKIE_SAME_SITE=Lax

# ---- Email (Brevo) ----
KLASIO_EMAIL_TRANSPORT=brevo
KLASIO_EMAIL_FROM_ADDRESS=noreply@klasio.club
AUTH_FROM_EMAIL=noreply@klasio.club
BREVO_API_KEY=xkeysib-...

# ---- Object storage (Cloudflare R2, S3-compatible) ----
# R2 endpoint: https://<account-id>.r2.cloudflarestorage.com
AWS_S3_BUCKET=klasio-prod
AWS_REGION=auto
AWS_S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# ---- Caddy / TLS ----
# Cloudflare API token with permission Zone:DNS:Edit on klasio.club only.
# Required for the DNS-01 challenge that issues the *.klasio.club wildcard cert.
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=CHANGE_ME

# Email used by Let's Encrypt for expiry/renewal notices.
ACME_EMAIL=tu-email@ejemplo.com
